{
    "name": "dockview-modules",
    "version": "7.0.4",
    "private": true,
    "description": "Separable feature modules for dockview",
    "keywords": [
        "dockview",
        "layout",
        "layout manager",
        "docking",
        "modules"
    ],
    "homepage": "https://github.com/mathuo/dockview",
    "bugs": {
        "url": "https://github.com/mathuo/dockview/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mathuo/dockview.git"
    },
    "license": "MIT",
    "author": "https://github.com/mathuo",
    "main": "./dist/package/main.cjs.js",
    "module": "./dist/package/main.esm.mjs",
    "types": "./dist/cjs/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build:bundle": "rollup -c",
        "build:cjs": "tsc --build ./tsconfig.json --verbose --extendedDiagnostics",
        "build:esm": "tsc --build ./tsconfig.esm.json --verbose --extendedDiagnostics",
        "build": "npm run build:cjs && npm run build:esm",
        "clean": "rimraf dist/ .build/ .rollup.cache/",
        "rebuild": "npm run clean && npm run build",
        "test": "jest --selectProjects dockview-modules",
        "test:cov": "jest --selectProjects dockview-modules --coverage",
        "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}'",
        "lint:fix": "eslint 'src/**/*.{ts,tsx,js,jsx}' --fix",
        "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
        "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx}'"
    },
    "dependencies": {
        "dockview-core": "^7.0.4"
    }
}
